import("../../../../testing/test.gni")
import("../../../Lynx.gni")

# ui_wrapper_painting_shared_sources
ui_wrapper_painting_shared_sources = [
  "catalyzer.cc",
  "catalyzer.h",
  "native_painting_context.cc",
  "native_painting_context.h",
  "native_painting_context_platform_ref.cc",
  "native_painting_context_platform_ref.h",
  "painting_context.cc",
  "painting_context.h",
  "platform_renderer.h",
  "platform_renderer_impl.cc",
  "platform_renderer_impl.h",
]

if (!enable_unittests) {
  if (is_android) {
    ui_wrapper_painting_shared_sources += [
      "android/native_painting_context_android.cc",
      "android/native_painting_context_android.h",
      "android/native_painting_context_platform_android_ref.cc",
      "android/native_painting_context_platform_android_ref.h",
      "android/painting_context_android.cc",
      "android/painting_context_android.h",

      # The following implementations are used for FlattenView rendering.
      "android/platform_renderer_android.cc",
      "android/platform_renderer_android.h",
      "android/platform_renderer_context.cc",
      "android/platform_renderer_context.h",
      "android/ui_delegate_android.cc",
      "android/ui_delegate_android.h",
    ]
  } else if (is_harmony) {
    ui_wrapper_painting_shared_sources += [
      "harmony/painting_context_harmony.cc",
      "harmony/painting_context_harmony.h",
      "harmony/ui_delegate_harmony.cc",
      "harmony/ui_delegate_harmony.h",
    ]
  } else if (is_ios) {
    ui_wrapper_painting_shared_sources += [
      "ios/native_painting_context_darwin.h",
      "ios/native_painting_context_darwin.mm",
      "ios/native_painting_context_platform_darwin_ref.h",
      "ios/native_painting_context_platform_darwin_ref.mm",
      "ios/painting_context_darwin.h",
      "ios/painting_context_darwin.mm",
      "ios/painting_context_darwin_utils.h",
      "ios/painting_context_darwin_utils.mm",
      "ios/platform_renderer_context_darwin.h",
      "ios/platform_renderer_context_darwin.mm",
      "ios/platform_renderer_darwin.h",
      "ios/platform_renderer_darwin.mm",
      "ios/platform_renderer_darwin_factory.h",
      "ios/platform_renderer_darwin_factory.mm",
      "ios/ui_delegate_darwin.h",
      "ios/ui_delegate_darwin.mm",
    ]
  }
}

lynx_core_source_set("painting") {
  sources = ui_wrapper_painting_shared_sources

  deps = [
    "../../../public",
    "../../../value_wrapper:value_wrapper",
    "../../starlight:starlight",
    "../../trace:renderer_trace",
    "../common",
  ]
}
