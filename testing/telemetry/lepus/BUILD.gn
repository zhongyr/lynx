import("../../../testing/test.gni")

lepus_benchmark_deps = [
  ":lepus_benchmark_test_files",
  "../../../core/renderer:tasm",
  "../../../core/renderer/dom:dom",
  "../../../core/renderer/dom:renderer_dom",
  "../../../core/runtime/lepus/bindings:bindings",
  "//third_party/googletest:gtest",
]

benchmark_test("lepus_benchmark") {
  testonly = true
  sources = [ "lepus_benchmark.cc" ]
  deps = lepus_benchmark_deps
}

benchmark_test("lepus_heap_sensitive_benchmark") {
  testonly = true
  sources = [ "lepus_heap_sensitive_benchmark.cc" ]
  deps = lepus_benchmark_deps
}

benchmark_test("lepus_js_snippet_benchmark") {
  testonly = true
  sources = [ "lepus_js_snippet_benchmark.cc" ]
  deps = lepus_benchmark_deps
}

benchmark_test("lepus_js_array_snippet_benchmark") {
  testonly = true
  sources = [ "lepus_js_array_snippet_benchmark.cc" ]
  deps = lepus_benchmark_deps
}

copy("lepus_benchmark_test_files") {
  sources = [
    "big_object.js",
    "leak_objects.js",
  ]
  outputs = [ "$root_out_dir/benchmark_test_files/{{source_file_part}}" ]
}
